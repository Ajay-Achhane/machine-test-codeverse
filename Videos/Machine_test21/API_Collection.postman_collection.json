{
  "info": {
    "name": "Usage Tracking API",
    "description": "Postman collection for Usage Tracking API with all routes and payloads",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "User Routes",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/signup",
              "host": ["{{baseUrl}}"],
              "path": ["signup"]
            },
            "description": "Register a new user account"
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Login with email and password to get JWT token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Usage Routes",
      "item": [
        {
          "name": "Record Usage",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"action\": \"api_call\",\n  \"usedUnits\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/usage",
              "host": ["{{baseUrl}}"],
              "path": ["usage"]
            },
            "description": "Record usage for a specific user action"
          },
          "response": []
        },
        {
          "name": "Get Current Usage",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/:id/current-usage",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id", "current-usage"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "User ID"
                }
              ]
            },
            "description": "Get current usage details for a user including remaining units"
          },
          "response": []
        },
        {
          "name": "Get Billing Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/:id/billing-summary",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id", "billing-summary"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "User ID"
                }
              ]
            },
            "description": "Get billing summary including total usage, extra units, and extra charges"
          },
          "response": []
        }
      ]
    }
  ]
}
